BASE_URL='https://givery.co.jp/'
HEADLESS=true
ACCOUNTS_JSON=".accounts.dev.json"

# Reporting API Basic authentication header
REPORTING_API_BASIC_AUTH='Basic <base64-encoded-credentials>'

# Direct URL of the Reporting API server (bypasses the frontend reverse proxy)
REPORTING_API_BASE_URL='https://api.<environment-domain>'

# LM Studio local server (OpenAI-compatible API)
LM_STUDIO_BASE_URL='http://localhost:1234/v1'

# Applicant answer TTS for VirtualMicrophone.
# "auto" uses macOS `say` on macOS and Windows SAPI through PowerShell on Windows.
APPLICANT_ANSWER_TTS_PROVIDER='auto'
APPLICANT_ANSWER_TTS_VOICE='Kyoko'

# Optional Windows-specific overrides. The voice must be installed in Windows Speech settings.
APPLICANT_ANSWER_TTS_WINDOWS_VOICE=''
APPLICANT_ANSWER_TTS_POWERSHELL_PATH='powershell.exe'

# Optional Windows voice mappings for scenario voices.
# The suffix is the scenario voice uppercased with non-alphanumeric characters replaced by "_".
# This keeps English/Japanese tests dynamic when they run together.
APPLICANT_ANSWER_TTS_WINDOWS_VOICE_KYOKO=''
APPLICANT_ANSWER_TTS_WINDOWS_VOICE_SAMANTHA=''
