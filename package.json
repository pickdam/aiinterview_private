{
  "name": "qa-playwright-e2e-boilerplate",
  "version": "1.0.0",
  "type": "module",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "lint": "eslint src --fix",
    "prepare": "husky",
    "format": "npx prettier --write .",
    "format:check": "prettier --check .",
    "type:check": "npx tsc -p tsconfig.json --noEmit"
  },
  "description": "Boilerplate for a Playwright Functional/e2e testing suite",
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@playwright/test": "^1.55.0",
    "@types/node": "^22.14.1",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-playwright": "^2.2.0",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.1",
    "prettier": "3.5.3",
    "typescript-eslint": "^8.30.1"
  },
  "dependencies": {
    "dotenv": "^16.4.7"
  },
  "lint-staged": {
    "**/*": [
      "prettier --write --ignore-unknown",
      "eslint . --fix"
    ]
  }
}
